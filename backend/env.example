# ─── Copy this file to .env and fill in your values ───────────
# DO NOT commit .env to GitHub!

# MongoDB Atlas connection string
# Get from: https://mongodb.com/atlas → Connect → Drivers
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/dropvault?retryWrites=true&w=majority

# Cloudinary credentials
# Get from: https://cloudinary.com → Dashboard
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_api_key
CLOUD_API_SECRET=your_api_secret

# Server port (Render sets this automatically)
PORT=3001
